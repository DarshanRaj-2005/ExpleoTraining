{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "types": ["node", "@playwright/test"],

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "sourceMap": true
  },
  "include": [
    "*.ts",
    "playwright.config.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}