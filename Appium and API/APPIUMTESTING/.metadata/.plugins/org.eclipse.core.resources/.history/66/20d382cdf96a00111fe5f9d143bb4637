package Appium;

import java.net.URL;
import java.time.Duration;
import org.testng.Assert;
import org.testng.annotations.AfterTest;
import org.testng.annotations.BeforeTest;
import org.testng.annotations.Test;
import io.appium.java_client.AppiumBy;
import io.appium.java_client.android.AndroidDriver;
import io.appium.java_client.android.options.UiAutomator2Options;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.ExpectedConditions;

public class Calculator {
	
    AndroidDriver driver;
    WebDriverWait wait;
    
    public void click(By locator) {
        driver.findElement(locator).click();
    }
    
    public String getText(By locator) {
    	return wait.until(ExpectedConditions.visibilityOfElementLocated(locator)).getText();
    }
    
    @BeforeTest
    public void beforeTest() throws Exception {
        UiAutomator2Options options = new UiAutomator2Options();
        options.setPlatformName("Android");
        options.setAutomationName("UiAutomator2");
        options.setDeviceName("Android");
        options.setUdid("mvs4gu4tkfytuosw");
        options.setAppPackage("com.google.android.calculator");
        options.setAppActivity("com.android.calculator2.Calculator");
        options.setNoReset(true);
        options.setCapability("skipDeviceInitialization", true);
        options.setCapability("ignoreHiddenApiPolicyError", true);
        options.setCapability("autoGrantPermissions", false);
        options.setCapability("uiautomator2ServerLaunchTimeout", 120000);
        options.setCapability("adbExecTimeout", 120000);
        System.out.println("Starting Appium Session...");

        driver = new AndroidDriver(
                new URL("http://127.0.0.1:4723"),
                options);
        wait = new WebDriverWait(driver,Duration.ofSeconds(15));
        System.out.println("Session Started Successfully");
    }

    @Test
    public void addNum() throws Exception {
        click(AppiumBy.id("com.google.android.calculator:id/digit_2"));
        click(AppiumBy.id("com.google.android.calculator:id/op_add"));
        click(AppiumBy.id("com.google.android.calculator:id/digit_5"));
        click(AppiumBy.id("com.google.android.calculator:id/eq"));
        String res = getText(AppiumBy.id("com.google.android.calculator:id/result_final"));
        System.out.println("Result of Addition: " + res);
        Assert.assertEquals(res, "7");
    }
    
    
    public void subractNum() throws Exception {
    	click(AppiumBy.id("com.google.android.calculator:id/digit_9"));
    	click(AppiumBy.id("com.google.android.calculator:id/op_sub"));
    	click(AppiumBy.id("com.google.android.calculator:id/digit_3"));
    	click(AppiumBy.id("com.google.android.calculator:id/eq"));
    	String res = getText(AppiumBy.id("com.google.android.calculator:id/formula"));
    	System.out.println("Result of Subraction: " + res);
    	Assert.assertEquals(res,"6");
    }
    
    @AfterTest
    public void afterTest() {
        if (driver != null) {
            driver.quit();
        }
    }
}